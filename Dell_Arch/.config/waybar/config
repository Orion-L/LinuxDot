{
    "height": 25,

    "modules-left": ["cpu", "memory", "temperature", "disk", "disk#disk2"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["sway/mode", "idle_inhibitor", "pulseaudio", "backlight", "network", "battery", "clock", "tray"],

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "<span font=\"MaterialIcon 14\">юг┤</span>",
            "deactivated": "<span font=\"MaterialIcon 14\">юг╡</span>"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
	      "format": "{:%H:%M %d/%m/%y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
    },
    "cpu": {
        "format": "яЛЫ {usage}%"
    },
    "memory": {
        "format": "яФ╕ {}%"
    },
    "disk": {
        "format": "{path} {free}",
        "path": "/"
    },
    "disk#disk2": {
        "format": "{path} {free}",
        "path": "/home"
    },
    "temperature": {
        "critical-threshold": 80,
        "format-critical": "яЯд {temperatureC}┬░C",
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛЗ"],
	      "tooltip": false
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["яЧА"]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яГз {capacity}%",
        "format-plugged": "яГз {capacity}%",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "network": {
        "format-wifi": "яЗл {signalStrength}%",
        "format-ethernet": "яЮЦ",
        "format-linked": "яЮЦ",
        "format-disconnected": "яБ▒",
	      "tooltip-format-wifi": "{essid} {ipaddr}/{cidr}",
	      "on-click": "swaymsg exec '$term -e nmtui'"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яКФ {volume}%",
        "format-bluetooth-muted": "яЪй",
        "format-muted": "яЪй",
        "format-icons": {
            "headphone": "яЦП",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pulsemixer --toggle-mute",
	      "on-click-right": "pavucontrol"
    }
}
