colorscheme wal

filetype plugin on
filetype indent on

set autoread
au FocusGained,BufEnter * checktime

set ruler

set cmdheight=1

set backspace=eol,start,indent
set whichwrap+=<,>,h,l

set ignorecase
set smartcase
set hlsearch
set incsearch
set showmatch

syntax enable

set background=dark

set encoding=utf8

set ffs=unix,dos,mac

set expandtab
set smarttab
set shiftwidth=4
set tabstop=4
set ai
set si
set wrap
set number
